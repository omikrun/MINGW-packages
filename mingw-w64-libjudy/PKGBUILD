apply_patch_with_msg() {
  for _patch in "$@"; do
    msg2 "Applying $_patch"
    patch -Nbp1 -i "${srcdir}/$_patch"
  done
}

prepare() {
  cd "${_realname}-${pkgver}-netdata2"

  # Taken from https://sources.debian.org/patches/judy/1.0.5-5.1/
  apply_patch_with_msg \
    01_notrans_man.patch \
    02_remove_duplicate_man.patch \
    03_add_man_section_to_filename.patch

  # Improve portability
  apply_patch_with_msg \
    0001-judy-no-undefined.patch \
    0002-fix-warnings.patch

  # Fixes directory not exist
  mkdir -p doc/man/man3

  autoreconf -fi
}

build() {
  cd "${_realname}-${pkgver}-netdata2"

  ./configure \
    --prefix="${MINGW_PREFIX}" \
    --build="${MINGW_CHOST}" \
    --host="${MINGW_CHOST}" \
    --target="${MINGW_CHOST}"

  # Parallel make is broken
  make -j1
}

package() {
  cd "${_realname}-${pkgver}-netdata2"

  make install DESTDIR="${pkgdir}"

  install -Dm644 "COPYING" -t "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}"
}
