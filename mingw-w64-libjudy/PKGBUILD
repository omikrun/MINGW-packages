_realname=libjudy
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=1.0.5
pkgrel=1
pkgdesc='C library for creating and accessing dynamic arrays'
arch=('any')
mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
license=('spdx:LGPL-2.1-or-later')
makedepends=("${MINGW_PACKAGE_PREFIX}-cc")
url='http://judy.sourceforge.net'
source=("https://github.com/netdata/libjudy/archive/v${pkgver}-netdata2/${_realname}-${pkgver}-netdata2.tar.gz"
        "0001-judy-no-undefined.patch"
        "0002-fix-warnings.patch"
        "01_notrans_man.patch"
        "02_remove_duplicate_man.patch"
        "03_add_man_section_to_filename.patch")
